APP_NAME=UnumPay Analytics API
APP_VERSION=1.0.0
DEBUG=True

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/unumpay_db

# Redis (for Celery background tasks)
REDIS_URL=redis://localhost:6379/0

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50

# CORS — add your Flutter web origin here
ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8080
